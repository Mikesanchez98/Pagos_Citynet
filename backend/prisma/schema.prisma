// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl= env("DIRECT_URL")
}

model Usuario {
  id            String   @id @default(uuid())
  email         String   @unique
  password      String
  rol           String   @default("CLIENTE") // ADMIN, CLIENTE
  cliente       Cliente?
}

model Cliente {
  id            Int       @id @default(autoincrement())
  nombre        String
  numCliente    String    @unique
  email         String?
  telefono      String?
  usuario       Usuario   @relation(fields: [usuarioId], references: [id])
  usuarioId     String    @unique
  servicios     Servicio[]
  diaCobro      Int       @default(1)
  direccion     String?
  latitud       Float?
  longitud      Float?

  //Relacion con la torre
  torreId       Int?
  torre         Torre?    @relation(fields: [torreId], references: [id])

  pagos         Pago[]
  tickets       Ticket[]

  paqueteId     String?
  paquete       Paquete?  @relation(fields: [paqueteId], references: [id])
}

model Torre {
  id            Int       @id @default(autoincrement())
  nombre        String
  latitud       Float?
  longitud      Float?
  clientes      Cliente[] //Relacion: Una torre alimenta a muchos clientes
}

model Servicio {
  id          Int      @id @default(autoincrement())
  plan        String   // Ej: 20 Megas
  precio      Decimal  @db.Decimal(10, 2)
  direccionIp String?  @default("192.168.1.1") // <--- AGREGA ESTO
  estado      String   @default("ACTIVO")
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  clienteId   Int
  facturas    Factura[]
}

model Factura {
  id          Int      @id @default(autoincrement())
  monto       Decimal  @db.Decimal(10, 2)
  vencimiento DateTime
  pagada      Boolean  @default(false)
  servicio    Servicio @relation(fields: [servicioId], references: [id])
  servicioId  Int
}

model Pago {
  id          Int      @id @default(autoincrement())
  monto       Float
  fecha       DateTime @default(now())
  mesCorrespondiente  String 
  metodoPago  String 
  notas       String?

  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
}

model Ticket{
  id          Int      @id @default(autoincrement())
  titulo      String   // Ej: "Sin internet", "Falla de router"
  descripcion String?  @db.Text // Detalles del reporte
  estatus     String   @default("PENDIENTE") // PENDIENTE, EN PROCESO, RESUELTO
  prioridad   String   @default("MEDIA")     // ALTA, MEDIA, BAJA
  notasAdmin  String?  @db.Text // Notas internas de los técnicos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relación con Cliente
  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Paquete{
  id          String   @id @default(uuid())
  nombre      String  
  velocidad   Int
  precio      Float
  descripcion String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  //En caso de que algun paquete se vinculen clientes a los paquetes
  clientes    Cliente[]
}