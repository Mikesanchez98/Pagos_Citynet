// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  rol      String   @default("CLIENTE") // ADMIN, CLIENTE
  cliente  Cliente?
}

model Cliente {
  id          Int        @id @default(autoincrement())
  nombre      String
  numCliente  String     @unique
  email       String?
  telefono    String?
  saldo       Float      @default(0)
  diaCobro    Int        @default(1)

  // Relaciones Globales
  usuarioId   String     @unique
  usuario     Usuario    @relation(fields: [usuarioId], references: [id])
  servicios   Servicio[]
  facturas    Factura[]
  pagos       Pago[]
  tickets     Ticket[]

  clientesMikrotik  ClienteMikrotik[]
}

model Torre {
  id          Int        @id @default(autoincrement())
  nombre      String
  descripcion String?
  latitud     Float?
  longitud    Float?

  //Ip principal de la torre
  ipPrincipal String?
  
  // Relaciones
  servicios   Servicio[]
  antenas     Antena[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Servicio {
  id          Int      @id @default(autoincrement())
  estado      String   @default("ACTIVO")
  
  // Vínculo directo con PPPoE secret en MikroTik
  mikrotikUser String? @unique

  // 🆕 MAC ADDRESS
  macAddress  String?

  direccionIp String?  @default("192.168.1.1")
  
  // 📍 Datos físicos
  direccion   String?
  latitud     Float?
  longitud    Float?
  
  // Relación con Torre
  torreId     Int?
  torre       Torre?   @relation(fields: [torreId], references: [id])
  
  // 🆕 Relación con Antena (IMPORTANTE - SIN ESTO FALLA)
  antenaId    Int?
  antena      Antena?  @relation(fields: [antenaId], references: [id], onDelete: SetNull)
  
  // 🆕 Sincronización
  ultimaSincronizacion DateTime?
  
  // Paquete y Cliente
  paqueteId   String
  paquete     Paquete @relation(fields: [paqueteId], references: [id])

  clienteId   Int
  cliente     Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  
  // 🆕 Historial de cambios
  cambiosAntena CambioAntena[]
}

model Factura {
  id          Int      @id @default(autoincrement())
  monto       Float    // Cambiado de Decimal a Float para unificar el manejo de dinero
  vencimiento DateTime
  pagada      Boolean  @default(false)
  
  // 👤 La factura se emite a la cuenta global del cliente
  clienteId   Int
  cliente     Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Pago {
  id                  Int      @id @default(autoincrement())
  monto               Float
  fecha               DateTime @default(now())
  mesCorrespondiente String 
  metodoPago          String 
  notas               String?

  clienteId           Int
  cliente             Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          Int      @id @default(autoincrement())
  titulo      String   // Ej: "Sin internet", "Falla de router"
  descripcion String?  @db.Text // Detalles del reporte
  estatus     String   @default("PENDIENTE") // PENDIENTE, EN PROCESO, RESUELTO
  prioridad   String   @default("MEDIA")     // ALTA, MEDIA, BAJA
  notasAdmin  String?  @db.Text // Notas internas de los técnicos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relación con Cliente
  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Paquete {
  id          String     @id @default(uuid())
  nombre      String  
  velocidad   Int
  precio      Float
  descripcion String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Los servicios que tienen contratado este paquete
  servicios   Servicio[]
}

model Antena{
  id          Int        @id @default(autoincrement())
  nombre      String     @unique
  descripcion String?

  //IP de la antena (gateway)
  ipGateway   String?
  subred      String?

  //Relacion con Torre
  torreId     Int
  torre       Torre      @relation(fields: [torreId], references: [id], onDelete: Cascade)

  //Relacion con Servicios 
  servicios   Servicio[]

  ///Metadata de Mikrotik
  interfaceName String?
  tipoInterfaz  String?

  activa     Boolean     @default(true)

  //Historial de cambios
  cambiosAnterior CambioAntena[]  @relation("CambioAnterior")
  cambiosActual   CambioAntena[]  @relation("CambioActual")

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model CambioAntena {
  id              Int       @id @default(autoincrement())
  
  servicioId      Int
  servicio        Servicio  @relation(fields: [servicioId], references: [id], onDelete: Cascade)
  
  antenaAnteriorId Int?
  antenaAnterior  Antena?   @relation("CambioAnterior", fields: [antenaAnteriorId], references: [id])
  
  antenaActualId  Int
  antenaActual    Antena    @relation("CambioActual", fields: [antenaActualId], references: [id])
  
  ipAnterior      String?
  ipActual        String?
  
  macAddress      String?
  
  detectedBy      String
  razon           String?
  
  timestamp       DateTime  @default(now())
}

// ===== MIKROTIK INTEGRATION =====

model ClienteMikrotik {
  id              Int     @id @default(autoincrement())
  numCliente      String  @unique
  nombreMikrotik  String
  profile         String
  routerOrigen    String
  servicio        String
  deshabilitado   Boolean @default(false)
  
  sincronizado    Boolean @default(false)
  clienteId       Int?
  cliente         Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MikrotikLog {
  id        Int     @id @default(autoincrement())
  accion    String
  cliente   String
  router    String
  estado    String
  error     String?
  timestamp DateTime @default(now())
}