// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id       String   @id @default(uuid())
  email    String   @unique
  password String
  rol      String   @default("CLIENTE") // ADMIN, CLIENTE
  cliente  Cliente?
}

model Cliente {
  id          Int        @id @default(autoincrement())
  nombre      String
  numCliente  String     @unique
  email       String?
  telefono    String?
  saldo       Float      @default(0)
  diaCobro    Int        @default(1)

  // Relaciones Globales
  usuarioId   String     @unique
  usuario     Usuario    @relation(fields: [usuarioId], references: [id])
  servicios   Servicio[]
  facturas    Factura[]
  pagos       Pago[]
  tickets     Ticket[]
}

model Torre {
  id          Int        @id @default(autoincrement())
  nombre      String
  latitud     Float?
  longitud    Float?
  
  // Relacion: Una torre alimenta a muchas instalaciones/servicios
  servicios   Servicio[] 
}

model Servicio {
  id          Int      @id @default(autoincrement())
  estado      String   @default("ACTIVO")
  direccionIp String?  @default("192.168.1.1")
  
  // 📍 Datos físicos de esta instalación en particular
  direccion   String?
  latitud     Float?
  longitud    Float?
  
  // Relacion con la torre
  torreId     Int?
  torre       Torre?   @relation(fields: [torreId], references: [id])
  
  // 📦 El paquete contratado para esta instalación (Temporalmente opcional para salvar tus datos)
  paqueteId   String
  paquete     Paquete @relation(fields: [paqueteId], references: [id])

  // 👤 El dueño de este servicio
  clienteId   Int
  cliente     Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Factura {
  id          Int      @id @default(autoincrement())
  monto       Float    // Cambiado de Decimal a Float para unificar el manejo de dinero
  vencimiento DateTime
  pagada      Boolean  @default(false)
  
  // 👤 La factura se emite a la cuenta global del cliente
  clienteId   Int
  cliente     Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Pago {
  id                  Int      @id @default(autoincrement())
  monto               Float
  fecha               DateTime @default(now())
  mesCorrespondiente String 
  metodoPago          String 
  notas               String?

  clienteId           Int
  cliente             Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Ticket {
  id          Int      @id @default(autoincrement())
  titulo      String   // Ej: "Sin internet", "Falla de router"
  descripcion String?  @db.Text // Detalles del reporte
  estatus     String   @default("PENDIENTE") // PENDIENTE, EN PROCESO, RESUELTO
  prioridad   String   @default("MEDIA")     // ALTA, MEDIA, BAJA
  notasAdmin  String?  @db.Text // Notas internas de los técnicos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relación con Cliente
  clienteId   Int
  cliente     Cliente  @relation(fields: [clienteId], references: [id], onDelete: Cascade)
}

model Paquete {
  id          String     @id @default(uuid())
  nombre      String  
  velocidad   Int
  precio      Float
  descripcion String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Los servicios que tienen contratado este paquete
  servicios   Servicio[]
}